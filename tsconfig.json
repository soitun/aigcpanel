{
    "compilerOptions": {
        "target": "ESNext",
        "useDefineForClassFields": true,
        "module": "ESNext",
        "moduleResolution": "Node",
        "strict": true,
        "jsx": "preserve",
        "resolveJsonModule": true,
        "isolatedModules": true,
        "esModuleInterop": true,
        "lib": ["ESNext", "DOM"],
        "skipLibCheck": true,
        "noEmit": true,
        "noImplicitAny": false,
        "allowJs": true
    },
    "include": ["src", "node_modules/unplugin-icons/types/vue.d.ts"],
    "references": [
        {
            "path": "./tsconfig.node.json"
        }
    ]
}
